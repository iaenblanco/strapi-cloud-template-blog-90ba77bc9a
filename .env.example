APP_KEYS=abc123key1,def456key2
API_TOKEN_SALT=Zy9aPeY1GKL3v8WbRr7T2A==
ADMIN_JWT_SECRET=MyAdminSecret123
TRANSFER_TOKEN_SALT=Tr4nsf3rS4lt987
JWT_SECRET=JWTSecret2025!

# ============================================================================
# KiteProp integration (Phase 1 — Properties only)
# ============================================================================

# Required — KiteProp API credentials
KITEPROP_API_KEY=kp_xxxxxxxxxxxxxxxxxxxxxxxxxx
KITEPROP_BASE_URL=https://www.kiteprop.com/api/v1

# Required — Token used to authenticate manual sync trigger endpoints.
# Sent via header: `Authorization: Bearer <token>`. Never via URL/query string.
# Generate a long random string. Rotate independently from KITEPROP_API_KEY.
KITEPROP_SYNC_TRIGGER_TOKEN=replace-with-a-long-random-string

# Master switch for the cron-driven sync. Cron also requires CRON_ENABLED=true.
# Default OFF for Phase 1.
KITEPROP_SYNC_ENABLED=false

# Default behavior of manual triggers when no `dryRun` body param is provided,
# and behavior of cron when KITEPROP_SYNC_ENABLED=true. Default ON in Phase 1.
KITEPROP_SYNC_DRY_RUN=true

# Phase 1 enforces "soft" — any other value is rejected at runtime.
KITEPROP_DELETE_STRATEGY=soft

# ----- Optional tuning (safe defaults are used when omitted) -----------------

# HTTP client tuning
# KITEPROP_SYNC_REQUEST_TIMEOUT_MS=20000
# KITEPROP_SYNC_MAX_RETRIES=5
# KITEPROP_SYNC_RETRY_BASE_MS=500

# Pagination & lock
# KITEPROP_SYNC_PAGE_SIZE_PROPERTIES=50
# KITEPROP_SYNC_DELTA_MAX_PAGES=20
# KITEPROP_SYNC_SNIFFER_MAX_PAGES=5
# KITEPROP_SYNC_LOCK_TIMEOUT_MS=600000

# Image mirroring from KiteProp CDN into Strapi Media Library.
# Keep ON if the public frontend reads the existing `Imagenes` media field.
# KITEPROP_SYNC_IMPORT_IMAGES=true
# KITEPROP_SYNC_IMAGE_TIMEOUT_MS=20000
# KITEPROP_SYNC_IMAGE_MAX_BYTES=15728640

# Tag → boolean mapping (CONFIGURABLE / TODO until confirmed by product)
# KITEPROP_TAGS_DESTACADO=destacado
# KITEPROP_TAGS_OPORTUNIDAD=oportunidad,oportunidades

# Cron (master switch + per-task schedule). Cron is OFF unless CRON_ENABLED=true.
# CRON_ENABLED=false
# KITEPROP_SYNC_PROPERTIES_DELTA_CRON=*/5 * * * *
# KITEPROP_SYNC_PROPERTIES_SNIFFER_CRON=30 */5 * * * *
# KITEPROP_SYNC_TIMEZONE=America/Santiago
